{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "enabledManagers": [
    "custom.regex"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^trek\\/build\\.yaml$/"
      ],
      "matchStrings": [
        "amd64: \\\"(?<depName>mauriceboe\\/trek):(?<currentValue>[^\\\"]+)\\\"",
        "aarch64: \\\"(?<depName>mauriceboe\\/trek):(?<currentValue>[^\\\"]+)\\\""
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^trek\\/config\\.yaml$/"
      ],
      "matchStrings": [
        "version: \\\"(?<currentValue>[0-9]+\\\\.[0-9]+\\\\.[0-9]+)\\\""
      ],
      "depNameTemplate": "mauriceboe/trek",
      "datasourceTemplate": "docker",
      "versioningTemplate": "semver"
    }
  ],
  "packageRules": [
    {
      "matchDepNames": [
        "mauriceboe/trek"
      ],
      "groupName": "TREK upstream version",
      "commitMessageTopic": "TREK",
      "automerge": false,
      "labels": [
        "dependencies"
      ]
    }
  ]
}
