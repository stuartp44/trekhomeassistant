{
  "$schema": "https://json.schemastore.org/commitlintrc",
  "extends": [
    "@commitlint/config-conventional"
  ],
  "parserPreset": {
    "parserOpts": {
      "headerPattern": "^\\[?(\\w+)(?:\\((.*)\\))?\\]?!?:?\\s(.+)$",
      "headerCorrespondence": [
        "type",
        "scope",
        "subject"
      ]
    }
  },
  "rules": {
    "type-enum": [
      2,
      "always",
      [
        "build",
        "chore",
        "ci",
        "docs",
        "feat",
        "fix",
        "perf",
        "refactor",
        "revert",
        "style",
        "test"
      ]
    ],
    "subject-empty": [
      2,
      "never"
    ],
    "header-max-length": [
      2,
      "always",
      100
    ]
  }
}
